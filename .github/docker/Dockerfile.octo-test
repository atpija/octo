FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# ------------------------------------------------------------
# System Dependencies
# ------------------------------------------------------------
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    ca-certificates \
    docker.io \
    python3 \
    python3-venv \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------
# Python Virtual Environment (PEP 668 compliant)
# ------------------------------------------------------------
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Upgrade tooling + install test deps inside venv
RUN pip install --upgrade pip setuptools wheel pytest

# ------------------------------------------------------------
# Python test deps
# ------------------------------------------------------------
RUN pip install pytest

# ------------------------------------------------------------
# Install Octo CLIENT only
# ------------------------------------------------------------
COPY temp/octo-client*.deb /tmp/

RUN dpkg -i /tmp/octo-client*.deb || \
    apt-get -f install -y && \
    rm -f /tmp/*.deb

# ------------------------------------------------------------
# Workspace
# ------------------------------------------------------------
WORKDIR /workspace

# ------------------------------------------------------------
# Default command = pytest
# (octo run überschreibt das automatisch)
# ------------------------------------------------------------
ENTRYPOINT ["pytest", "-s"]
