FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    curl wget git python3 python3-pip python3-venv ca-certificates \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

# Installiere Python Test und Development Dependencies
RUN pip install --upgrade pip setuptools wheel && \
    pip install pytest

# Kopiere alle .deb Dateien
COPY *.deb /tmp/

# Installiere alle .deb Dateien
RUN apt-get update && \
    apt-get install -y /tmp/*.deb && \
    rm /tmp/*.deb

# Erstelle ein Startup-Skript
RUN mkdir -p /app
COPY <<EOF /app/entrypoint.sh
#!/bin/bash
set -e

echo "🔐 Adding demo token to server..."
octo-server token-add demo-token

echo "🚀 Starting Octo Server..."
octo-server server &
SERVER_PID=$!

# Warte kurz, bis der Server startet
sleep 2

echo "🏃 Starting Octo Runner with demo token..."
octo-runner --token demo-token &
RUNNER_PID=$!

# Halte beide Prozesse am Laufen
wait $SERVER_PID $RUNNER_PID
EOF

RUN chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]
