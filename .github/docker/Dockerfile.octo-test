FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# ------------------------------------------------------------
# System Dependencies
# ------------------------------------------------------------
RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    python3 \
    python3-venv \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------
# Python Virtual Environment (PEP 668 compliant)
# ------------------------------------------------------------
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# ------------------------------------------------------------
# Python test deps
# ------------------------------------------------------------
RUN pip install --upgrade pip setuptools wheel pytest

# ------------------------------------------------------------
# Install Octo CLIENT only
# ------------------------------------------------------------
COPY temp/octo-client*.deb /tmp/
RUN dpkg -i /tmp/octo-client*.deb || apt-get -f install -y
RUN rm -f /tmp/*.deb

# ------------------------------------------------------------
# Workspace + tests
# ------------------------------------------------------------
WORKDIR /workspace
COPY test/smoketest.py /workspace/smoketest.py

# ------------------------------------------------------------
# Runtime ENV (optional defaults)
# ------------------------------------------------------------
ENV SERVER_URL=http://host.docker.internal:5000
ENV SMOKE_TOKEN=demo-token

# ------------------------------------------------------------
# AUTO-RUN PYTEST
# ------------------------------------------------------------
ENTRYPOINT ["python", "-m", "pytest"]
CMD ["-v", "smoketest.py"]
