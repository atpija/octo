FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    curl wget git python3 python3-pip python3-venv ca-certificates \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

# Installiere Python Test und Development Dependencies
RUN pip install --upgrade pip setuptools wheel && \
    pip install pytest

# Kopiere alle .deb Dateien
COPY temp/*.deb /tmp/

# Installiere alle .deb Dateien sicher
RUN dpkg -i /tmp/*.deb || apt-get -f install -y && \
    rm -f /tmp/*.deb

# Erstelle ein Startup-Skript
RUN mkdir -p /app
RUN cat > /app/entrypoint.sh << 'ENTRYPOINT_EOF'
#!/bin/bash
set -e

echo "🔐 Adding demo token to server..."
octo-server token-add demo-token

echo "🚀 Starting Octo Server..."
octo-server server &
SERVER_PID=$!

sleep 2

echo "🏃 Starting Octo Runner with demo token..."
octo-runner --token demo-token &
RUNNER_PID=$!

wait
ENTRYPOINT_EOF

RUN chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]
