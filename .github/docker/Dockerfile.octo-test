FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# ------------------------------------------------------------
# System Dependencies
# ------------------------------------------------------------
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    ca-certificates \
    docker.io \
    python3 \
    python3-venv \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------
# Python Virtual Environment (PEP 668 compliant)
# ------------------------------------------------------------
RUN python3 -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Upgrade tooling + install test deps inside venv
RUN pip install --upgrade pip setuptools wheel && \
    pip install pytest

# ------------------------------------------------------------
# Install Octo .deb packages
# ------------------------------------------------------------
COPY temp/*.deb /tmp/

RUN dpkg -i /tmp/*.deb || apt-get -f install -y && \
    rm -f /tmp/*.deb

# ------------------------------------------------------------
# Entrypoint
# ------------------------------------------------------------
RUN mkdir -p /app

RUN cat > /app/entrypoint.sh << 'ENTRYPOINT_EOF'
#!/bin/bash
set -e

echo "Adding demo token to server..."
octo-server token-add demo-token

echo "Starting Octo Server..."
octo-server server &
SERVER_PID=$!

sleep 2

echo "Starting Octo Runner with demo token..."
octo-runner --token demo-token &
RUNNER_PID=$!

wait
ENTRYPOINT_EOF

RUN chmod +x /app/entrypoint.sh

ENTRYPOINT ["/app/entrypoint.sh"]
