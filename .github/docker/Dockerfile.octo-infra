FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# ------------------------------------------------------------
# System Dependencies (minimal)
# ------------------------------------------------------------
RUN apt-get update && apt-get install -y \
    ca-certificates \
    curl \
    python3 \
    python3-venv \
    python3-pip \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

# ------------------------------------------------------------
# Ensure tmp exists and is writable
# ------------------------------------------------------------
RUN mkdir -p /tmp && chmod 1777 /tmp

# ------------------------------------------------------------
# Install Octo SERVER + RUNNER only
# ------------------------------------------------------------
COPY temp/octo-server*.deb /tmp/
COPY temp/octo-runner*.deb /tmp/

RUN dpkg -i /tmp/octo-server*.deb /tmp/octo-runner*.deb || \
    apt-get -f install -y && \
    rm -f /tmp/*.deb

# ------------------------------------------------------------
# Entrypoint
# ------------------------------------------------------------
RUN mkdir -p /app

RUN cat > /app/entrypoint.sh << 'EOF'
#!/bin/bash
set -e

echo "Adding demo token..."
octo-server token-add demo-token || true

echo "Starting Octo Server..."
octo-server server &
SERVER_PID=$!

sleep 2

echo "Starting Octo Runner..."
octo-runner --token demo-token &
RUNNER_PID=$!

wait
EOF

RUN chmod +x /app/entrypoint.sh

EXPOSE 5000

# ------------------------------------------------------------
# Workspace
# ------------------------------------------------------------
WORKDIR /workspace

ENTRYPOINT ["/app/entrypoint.sh"]
